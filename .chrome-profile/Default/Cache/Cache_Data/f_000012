<main class="admin-layout">
  <section class="admin-heading">
    <div>
      <p class="eyebrow">Admin dashboard</p>
      <h1>Quản lý sản phẩm</h1>
      <p>Thêm, sửa, xóa và theo dõi trạng thái sản phẩm cà phê trong cơ sở dữ liệu MySQL.</p>
    </div>
    <a class="btn primary" href="/admin/products/new">
      <i data-lucide="plus"></i>
      Thêm sản phẩm
    </a>
  </section>

  <section class="stats-grid">
    <article class="stat-card reveal">
      <span><i data-lucide="boxes"></i></span>
      <p>Tổng sản phẩm</p>
      <strong>9</strong>
    </article>
    <article class="stat-card reveal">
      <span><i data-lucide="badge-check"></i></span>
      <p>Còn hàng</p>
      <strong>7</strong>
