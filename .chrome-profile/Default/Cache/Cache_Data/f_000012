    <article class="stat-card reveal">
      <span><i data-lucide="badge-x"></i></span>
      <p>Hết hàng</p>
      <strong>2</strong>
    </article>
    <article class="stat-card reveal">
      <span><i data-lucide="tags"></i></span>
      <p>Danh mục</p>
      <strong>4</strong>
    </article>
  </section>

  <section class="admin-panel">
    <form class="admin-filters" action="/admin" method="get">
      <label class="search-box">
        <i data-lucide="search"></i>
        <input type="search" name="q" value="" placeholder="Tìm sản phẩm...">
      </label>
      <select name="category" aria-label="Lọc danh mục">
        <option value="">Tất cả danh mục</option>
        
          <option value="1" >
            Cà phê pha máy
          </option>
        
          <option value="2" >
            Cà phê truyền thống
          </option>
        
          <option value="3" >
            Cold Brew
          </option>
        
          <option value="4" >
            Trà trái cây
          </option>
        
      </select>
      <select name="status" aria-label="Lọc trạng thái">
        <option value="">Tất cả trạng thái</option>
        <option value="in_stock" >Còn hàng</option>
        <option value="out_of_stock" >Hết hàng</option>
      </select>
      <button class="btn dark" type="submit">
        <i data-lucide="list-filter"></i>
        Lọc
      </button>
      <a class="btn ghost" href="/admin">
        <i data-lucide="rotate-ccw"></i>
        Đặt lại
      </a>
    </form>

