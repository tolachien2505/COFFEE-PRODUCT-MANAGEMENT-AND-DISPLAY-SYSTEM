<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Dashboard | Coffee Product System</title>
  <meta name="description" content="Website quản lý và hiển thị sản phẩm cà phê với Express, EJS và MySQL.">
  <link rel="stylesheet" href="/css/styles.css">
