<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Coffee Product System</title>
  <meta name="description" content="Website quản lý và hiển thị sản phẩm cà phê với Express, EJS và MySQL.">
  <link rel="stylesheet" href="/css/styles.css">
  <script defer src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script defer src="/js/app.js"></script>
</head>
<body>
  <div class="site-shell">
    <header class="topbar">
      <a class="brand" href="/" aria-label="BeanHaus Coffee">
        <span class="brand-mark">BH</span>
        <span>
          <strong>BeanHaus</strong>
          <small>Coffee products</small>
        </span>
      </a>
      <nav class="main-nav" aria-label="Điều hướng chính">
        <a class="<%= activePage === 'showcase' ? 'active' : '' %>" href="/">
          <i data-lucide="coffee"></i>
          Sản phẩm
        </a>
        <a class="<%= activePage === 'admin' ? 'active' : '' %>" href="/admin">
          <i data-lucide="layout-dashboard"></i>
          Quản trị
        </a>
      </nav>
    </header>

    <% if (flash) { %>
      <div class="toast <%= flash.type %>" role="status" data-toast>
        <i data-lucide="<%= flash.type === 'error' ? 'circle-alert' : 'circle-check' %>"></i>
        <span><%= flash.message %></span>
      </div>
    <% } %>
