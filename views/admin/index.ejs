<%- include('../partials/head', { title, activePage, flash }) %>

<main class="admin-layout">
  <section class="admin-heading">
    <div>
      <p class="eyebrow">Admin dashboard</p>
      <h1>Quản lý sản phẩm</h1>
      <p>Thêm, sửa, xóa và theo dõi trạng thái sản phẩm cà phê trong cơ sở dữ liệu MySQL.</p>
    </div>
    <a class="btn primary" href="/admin/products/new">
      <i data-lucide="plus"></i>
      Thêm sản phẩm
    </a>
  </section>

  <section class="stats-grid">
    <article class="stat-card reveal">
      <span><i data-lucide="boxes"></i></span>
      <p>Tổng sản phẩm</p>
      <strong><%= stats.total %></strong>
    </article>
    <article class="stat-card reveal">
      <span><i data-lucide="badge-check"></i></span>
      <p>Còn hàng</p>
      <strong><%= stats.inStock %></strong>
    </article>
    <article class="stat-card reveal">
      <span><i data-lucide="badge-x"></i></span>
      <p>Hết hàng</p>
      <strong><%= stats.outOfStock %></strong>
    </article>
    <article class="stat-card reveal">
      <span><i data-lucide="tags"></i></span>
      <p>Danh mục</p>
      <strong><%= stats.totalCategories %></strong>
    </article>
  </section>

  <section class="admin-panel">
    <form class="admin-filters" action="/admin" method="get">
      <label class="search-box">
        <i data-lucide="search"></i>
        <input type="search" name="q" value="<%= query.q || '' %>" placeholder="Tìm sản phẩm...">
      </label>
      <select name="category" aria-label="Lọc danh mục">
        <option value="">Tất cả danh mục</option>
        <% categories.forEach((category) => { %>
          <option value="<%= category.Id %>" <%= String(query.category || '') === String(category.Id) ? 'selected' : '' %>>
            <%= category.Name %>
          </option>
        <% }) %>
      </select>
      <select name="status" aria-label="Lọc trạng thái">
        <option value="">Tất cả trạng thái</option>
        <option value="in_stock" <%= query.status === 'in_stock' ? 'selected' : '' %>>Còn hàng</option>
        <option value="out_of_stock" <%= query.status === 'out_of_stock' ? 'selected' : '' %>>Hết hàng</option>
      </select>
      <button class="btn dark" type="submit">
        <i data-lucide="list-filter"></i>
        Lọc
      </button>
      <a class="btn ghost" href="/admin">
        <i data-lucide="rotate-ccw"></i>
        Đặt lại
      </a>
    </form>

    <div class="table-wrap">
      <table class="product-table">
        <thead>
          <tr>
            <th>Sản phẩm</th>
            <th>Danh mục</th>
            <th>Giá</th>
            <th>Trạng thái</th>
            <th>Ngày tạo</th>
            <th class="actions-col">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% if (!products.length) { %>
            <tr>
              <td colspan="6">
                <div class="table-empty">
                  <i data-lucide="package-search"></i>
                  Không có sản phẩm phù hợp.
                </div>
              </td>
            </tr>
          <% } %>
          <% products.forEach((product) => { %>
            <tr>
              <td>
                <div class="table-product">
                  <img src="<%= product.Image_URL %>" alt="<%= product.Name %>" loading="lazy">
                  <div>
                    <strong><%= product.Name %></strong>
                    <span><%= product.Description %></span>
                  </div>
                </div>
              </td>
              <td><%= product.Category_Name %></td>
              <td><strong><%= format.currency(product.Price) %></strong></td>
              <td><span class="status-badge <%= product.Status %>"><%= format.statusLabel(product.Status) %></span></td>
              <td><%= format.date(product.Created_At) %></td>
              <td>
                <div class="row-actions">
                  <a class="icon-btn" href="/admin/products/<%= product.Id %>/edit" aria-label="Sửa <%= product.Name %>">
                    <i data-lucide="pencil"></i>
                  </a>
                  <button class="icon-btn danger delete-trigger"
                          type="button"
                          aria-label="Xóa <%= product.Name %>"
                          data-id="<%= product.Id %>"
                          data-name="<%= product.Name %>">
                    <i data-lucide="trash-2"></i>
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<div class="modal" id="deleteModal" aria-hidden="true">
  <div class="modal-backdrop" data-close-modal></div>
  <section class="modal-panel confirm-modal" role="dialog" aria-modal="true" aria-labelledby="deleteTitle">
    <button class="icon-btn close-modal" type="button" data-close-modal aria-label="Đóng">
      <i data-lucide="x"></i>
    </button>
    <span class="danger-icon"><i data-lucide="triangle-alert"></i></span>
    <h2 id="deleteTitle">Xóa sản phẩm?</h2>
    <p>Bạn có chắc muốn xóa <strong id="deleteName"></strong>? Thao tác này không thể hoàn tác.</p>
    <form id="deleteForm" method="post">
      <button class="btn ghost" type="button" data-close-modal>Hủy</button>
      <button class="btn danger" type="submit">
        <i data-lucide="trash-2"></i>
        Xóa
      </button>
    </form>
  </section>
</div>

<%- include('../partials/footer') %>
